import java.util.*;
public class methods {
	static boolean prime(int m)
	{
		boolean x;
		for(int i=2;i<=m/2;i++)
		{
			if(m%i==0)
			{
				return false;
			}
		}
		return true;
	}
	public static void main(String[] args) {
		int n;
		System.out.println("ENTER THE NUMBER");
		Scanner st=new Scanner(System.in);
		n=st.nextInt();
		System.out.println(prime(n));

	}

}

